#!/usr/bin/env python3
"""ports — local dev port registry with htop-style TUI."""

import curses
import json
import os
import signal
import subprocess
import sys
import textwrap

# ── Config ────────────────────────────────────────────────────────────────────
DATA_FILE = os.path.expanduser("~/.ports.json")

WELL_KNOWN_PORTS = [
    3000, 3001, 3002, 3003, 3004, 3005,
    4000, 4001,
    5000, 5001,
    5173,
    8000, 8001, 8002, 8003,
    8080, 8081, 8082, 8083,
    5432,
    3306,
    6379,
    27017,
]

PORT_TYPES = ("web", "api", "db", "cache", "proxy", "other")

# ── ANSI helpers for non-TUI output ──────────────────────────────────────────
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
MAGENTA = "\033[35m"

# ── Data helpers ──────────────────────────────────────────────────────────────
def load_data():
    if not os.path.exists(DATA_FILE):
        return {}
    try:
        with open(DATA_FILE) as f:
            return json.load(f)
    except (json.JSONDecodeError, IOError):
        return {}


def save_data(data):
    tmp = DATA_FILE + f".tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
    os.replace(tmp, DATA_FILE)


# ── Port detection ────────────────────────────────────────────────────────────
def get_listening_info():
    """Return dict of {port_number: process_name} for all listening TCP ports."""
    info = {}
    try:
        out = subprocess.run(
            ["lsof", "-iTCP", "-sTCP:LISTEN", "-P", "-n"],
            capture_output=True, text=True, timeout=5,
        )
        for line in out.stdout.splitlines()[1:]:
            parts = line.split()
            if len(parts) < 9:
                continue
            cmd = parts[0]
            addr = parts[8]
            port_str = addr.rsplit(":", 1)[-1]
            if port_str.isdigit():
                port = int(port_str)
                if port not in info:
                    info[port] = cmd
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    return info


def get_port_status(port, data, listening):
    """Return (status, project, type, tags, proc_name)."""
    key = str(port)
    is_reserved = key in data
    is_listening = port in listening

    if is_reserved:
        entry = data[key]
        project = entry.get("project", "")
        ptype = entry.get("type", "")
        tags = entry.get("tags", [])
        if is_listening:
            return "active", project, ptype, tags, ""
        else:
            return "reserved", project, ptype, tags, ""
    else:
        if is_listening:
            proc = listening.get(port, "???")
            return "inuse", proc, "", [], proc
        else:
            return "available", "", "", [], ""


def build_port_list(data):
    """Build sorted list of all ports to display (well-known + registered)."""
    ports = set(WELL_KNOWN_PORTS)
    for k in data:
        if k.isdigit():
            ports.add(int(k))
    return sorted(ports)


# ── CLI commands (non-curses) ─────────────────────────────────────────────────
def cmd_add(args):
    if len(args) < 2:
        print("Usage: ports add <port> <project> [key=value...]", file=sys.stderr)
        sys.exit(1)

    port_str, project = args[0], args[1]
    if not port_str.isdigit() or not (1 <= int(port_str) <= 65535):
        print(f"Error: invalid port number '{port_str}'", file=sys.stderr)
        sys.exit(1)

    ptype = "other"
    description = ""
    tags = []
    meta = {}

    for arg in args[2:]:
        if "=" not in arg:
            continue
        key, val = arg.split("=", 1)
        if key == "type":
            ptype = val
        elif key in ("desc", "description"):
            description = val
        elif key == "tags":
            tags = [t.strip() for t in val.split(",") if t.strip()]
        else:
            meta[key] = val

    data = load_data()
    data[port_str] = {
        "port": int(port_str),
        "project": project,
        "type": ptype,
        "description": description,
        "tags": tags,
        "meta": meta,
    }
    save_data(data)
    print(f"{GREEN}Reserved{RESET} port {BOLD}{port_str}{RESET} → {project} ({ptype})")


def cmd_rm(args):
    if len(args) < 1:
        print("Usage: ports rm <port>", file=sys.stderr)
        sys.exit(1)

    port_str = args[0]
    data = load_data()
    if port_str not in data:
        print(f"Error: port {port_str} not registered", file=sys.stderr)
        sys.exit(1)

    project = data[port_str].get("project", "")
    del data[port_str]
    save_data(data)
    print(f"{RED}Removed{RESET} port {BOLD}{port_str}{RESET} ({project})")


def cmd_check(args):
    if len(args) < 1:
        print("Usage: ports check <port>", file=sys.stderr)
        sys.exit(1)

    port = int(args[0])
    data = load_data()
    listening = get_listening_info()
    status, project, _, _, proc = get_port_status(port, data, listening)

    p = f"{BOLD}{port}{RESET}"
    if status == "active":
        print(f"{GREEN}●{RESET} Port {p} is {GREEN}active{RESET} — {CYAN}{project}{RESET} is running")
    elif status == "reserved":
        print(f"{YELLOW}◐{RESET} Port {p} is {YELLOW}reserved{RESET} by {CYAN}{project}{RESET} (not running)")
    elif status == "inuse":
        print(f"{MAGENTA}●{RESET} Port {p} is {MAGENTA}in use{RESET} by {MAGENTA}{proc}{RESET} (not registered)")
    else:
        print(f"{DIM}○{RESET} Port {p} is {DIM}available{RESET}")


def cmd_list(args):
    filt = None
    for a in args:
        if a == "--active":
            filt = "active"
        elif a == "--reserved":
            filt = "reserved"
        elif a == "--available":
            filt = "available"

    data = load_data()
    listening = get_listening_info()
    all_ports = build_port_list(data)

    print(f"{DIM}     {'PORT':<6} {'PROJECT':<20} {'TYPE':<8} {'TAGS':<24} STATUS{RESET}")
    print(f"{DIM}{'─' * 74}{RESET}")

    for port in all_ports:
        status, project, ptype, tags, proc = get_port_status(port, data, listening)
        if filt and status != filt:
            continue

        tags_str = f"[{', '.join(tags)}]" if tags else ""

        if status == "active":
            icon = f"{GREEN}●{RESET}"
            label = f"{GREEN}ACTIVE{RESET}"
            print(f"  {icon} {port:<6} {CYAN}{project:<20}{RESET} {DIM}{ptype:<8}{RESET} {YELLOW}{tags_str:<24}{RESET} {label}")
        elif status == "reserved":
            icon = f"{YELLOW}◐{RESET}"
            label = f"{YELLOW}RESERVED{RESET}"
            print(f"  {icon} {port:<6} {CYAN}{project:<20}{RESET} {DIM}{ptype:<8}{RESET} {YELLOW}{tags_str:<24}{RESET} {label}")
        elif status == "inuse":
            icon = f"{MAGENTA}●{RESET}"
            label = f"{MAGENTA}IN USE{RESET}"
            name = proc[:18]
            print(f"  {icon} {port:<6} {MAGENTA}{name:<20}{RESET} {DIM}{'':<8}{RESET} {DIM}{'':<24}{RESET} {label}")
        else:
            icon = f"{DIM}○{RESET}"
            label = f"{DIM}—{RESET}"
            print(f"  {icon} {DIM}{port:<6}{RESET} {DIM}{'':<20}{RESET} {DIM}{'':<8}{RESET} {DIM}{'':<24}{RESET} {label}")


# ── TUI (curses) ──────────────────────────────────────────────────────────────
def tui_main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()
    stdscr.timeout(50)  # 50ms — responsive input, no busy-wait
    stdscr.keypad(True)

    # Set up colors
    curses.init_pair(1, curses.COLOR_GREEN, -1)
    curses.init_pair(2, curses.COLOR_YELLOW, -1)
    curses.init_pair(3, curses.COLOR_CYAN, -1)
    curses.init_pair(4, curses.COLOR_MAGENTA, -1)
    curses.init_pair(5, curses.COLOR_RED, -1)
    curses.init_pair(6, curses.COLOR_WHITE, -1)

    C_GREEN = curses.color_pair(1)
    C_YELLOW = curses.color_pair(2)
    C_CYAN = curses.color_pair(3)
    C_MAGENTA = curses.color_pair(4)
    C_RED = curses.color_pair(5)
    C_WHITE = curses.color_pair(6)
    C_DIM = curses.A_DIM
    C_BOLD = curses.A_BOLD
    C_REV = curses.A_REVERSE

    selected = 0
    search_term = ""
    searching = False
    goto_term = ""
    goto_mode = False
    confirming_delete = False
    message = ""
    message_attr = 0

    data = load_data()
    listening = get_listening_info()

    while True:
        rows, cols = stdscr.getmaxyx()
        all_ports = build_port_list(data)

        # Filter by search
        if search_term:
            st = search_term.lower()
            display_ports = []
            for port in all_ports:
                key = str(port)
                if st in key:
                    display_ports.append(port)
                    continue
                if key in data:
                    entry = data[key]
                    if st in entry.get("project", "").lower():
                        display_ports.append(port)
                        continue
                    if any(st in t.lower() for t in entry.get("tags", [])):
                        display_ports.append(port)
                        continue
        else:
            display_ports = list(all_ports)

        # Clamp selection
        if len(display_ports) == 0:
            selected = 0
        elif selected >= len(display_ports):
            selected = len(display_ports) - 1
        if selected < 0:
            selected = 0

        # Stats
        active_count = 0
        reserved_count = 0
        for port in all_ports:
            s = get_port_status(port, data, listening)[0]
            if s == "active":
                active_count += 1
                reserved_count += 1
            elif s == "reserved":
                reserved_count += 1

        # ── Draw ──────────────────────────────────────────────────
        stdscr.erase()

        # Row 0: header
        header = ":: port registry"
        stats = f"{active_count} active · {reserved_count} reserved · {len(all_ports)} tracked"
        pad = max(1, cols - len(header) - len(stats))
        try:
            stdscr.addstr(0, 0, header, C_CYAN | C_BOLD)
            stdscr.addstr(0, len(header) + pad, stats, C_DIM)
        except curses.error:
            pass

        # Row 1: column headers
        try:
            stdscr.addstr(1, 0, f"   {'':2}{'PORT':<6} {'PROJECT':<18} {'TYPE':<8} {'TAGS':<23} STATUS", C_DIM | C_BOLD)
            stdscr.clrtoeol()
        except curses.error:
            pass

        # Row 2: separator
        try:
            stdscr.addstr(2, 0, "─" * cols, C_DIM)
        except curses.error:
            pass

        # Entries start at row 3
        max_entries = rows - 6
        # Scroll offset so selected is always visible
        scroll_offset = 0
        if selected >= max_entries:
            scroll_offset = selected - max_entries + 1

        row = 3
        for i, port in enumerate(display_ports):
            if i < scroll_offset:
                continue
            if row >= rows - 3:
                break

            status, project, ptype, tags, proc = get_port_status(port, data, listening)
            tags_str = f"[{', '.join(tags)}]" if tags else ""
            is_sel = (i == selected)

            try:
                # Full-row highlight for selected row
                if is_sel:
                    stdscr.addstr(row, 0, " " * min(cols, cols), C_REV)

                row_attr = C_REV if is_sel else 0

                # Leading space
                stdscr.addstr(row, 0, "   ", row_attr)
                col = 3

                # Status icon — icon color combined with reverse if selected
                if status == "active":
                    stdscr.addstr(row, col, "● ", C_GREEN | row_attr)
                elif status == "reserved":
                    stdscr.addstr(row, col, "◐ ", C_YELLOW | row_attr)
                elif status == "inuse":
                    stdscr.addstr(row, col, "● ", C_MAGENTA | row_attr)
                else:
                    stdscr.addstr(row, col, "○ ", C_DIM | row_attr)
                col += 2

                # Port number
                port_s = f"{port:<6}"
                if status == "available":
                    stdscr.addstr(row, col, port_s, C_DIM | row_attr)
                else:
                    stdscr.addstr(row, col, port_s, (C_BOLD if is_sel else 0) | row_attr)
                col += 6

                # Spacer
                stdscr.addstr(row, col, " ", row_attr)
                col += 1

                # Project / process name
                if status == "inuse":
                    name = proc[:18]
                    stdscr.addstr(row, col, f"{name:<18}", C_MAGENTA | row_attr)
                elif status == "available":
                    stdscr.addstr(row, col, f"{'':<18}", C_DIM | row_attr)
                else:
                    stdscr.addstr(row, col, f"{project[:18]:<18}", C_CYAN | row_attr)
                col += 18

                # Spacer
                stdscr.addstr(row, col, " ", row_attr)
                col += 1

                # Type
                stdscr.addstr(row, col, f"{ptype[:7]:<8}", C_DIM | row_attr)
                col += 8

                # Tags
                stdscr.addstr(row, col, f"{tags_str[:22]:<23}", (C_YELLOW if tags_str else C_DIM) | row_attr)
                col += 23

                # Status label
                if status == "active":
                    stdscr.addstr(row, col, "ACTIVE", C_GREEN | row_attr)
                elif status == "reserved":
                    stdscr.addstr(row, col, "RESERVED", C_YELLOW | row_attr)
                elif status == "inuse":
                    stdscr.addstr(row, col, "IN USE", C_MAGENTA | row_attr)
                else:
                    stdscr.addstr(row, col, "—", C_DIM | row_attr)

                # Fill rest of row with highlight if selected
                if is_sel:
                    cur_y, cur_x = stdscr.getyx()
                    if cur_x < cols:
                        stdscr.addstr(row, cur_x, " " * (cols - cur_x - 1), C_REV)

            except curses.error:
                pass

            row += 1

        # Bottom separator
        try:
            stdscr.addstr(rows - 3, 0, "─" * cols, C_DIM)
        except curses.error:
            pass

        # Status bar
        try:
            if message:
                stdscr.addstr(rows - 2, 1, message, message_attr)
            elif confirming_delete:
                port_to_rm = display_ports[selected]
                key = str(port_to_rm)
                proj = data.get(key, {}).get("project", "???")
                stdscr.addstr(rows - 2, 1, "Delete ", C_RED | C_BOLD)
                stdscr.addstr(f"port {port_to_rm} ({proj})? ")
                stdscr.addstr("[y]", C_BOLD)
                stdscr.addstr("es / ")
                stdscr.addstr("[n]", C_BOLD)
                stdscr.addstr("o")
            elif goto_mode:
                stdscr.addstr(rows - 2, 1, ":", C_BOLD)
                stdscr.addstr(goto_term)
                stdscr.addstr(" — enter port number, press Enter to jump, Esc to cancel", C_DIM)
            elif searching:
                stdscr.addstr(rows - 2, 1, "/", C_BOLD)
                stdscr.addstr(search_term)
                stdscr.addstr(" — press Enter to confirm, Esc to cancel", C_DIM)
            else:
                pairs = [("[a]", "dd"), ("[d]", "elete"), ("[r]", "efresh"), ("[/]", "search"), ("[:]", "goto"), ("[q]", "uit")]
                x = 1
                for key_label, rest in pairs:
                    stdscr.addstr(rows - 2, x, key_label, C_BOLD)
                    stdscr.addstr(rest)
                    x += len(key_label) + len(rest) + 2
        except curses.error:
            pass

        stdscr.refresh()

        # ── Input ─────────────────────────────────────────────────
        try:
            ch = stdscr.getch()
        except curses.error:
            continue

        if ch == -1:
            # timeout — no input, just loop (handles resize via erase+redraw)
            message = ""
            continue

        if ch == curses.KEY_RESIZE:
            message = ""
            continue

        # Clear transient messages on any keypress
        message = ""
        message_attr = 0

        if confirming_delete:
            if ch in (ord("y"), ord("Y")):
                port_to_rm = display_ports[selected]
                key = str(port_to_rm)
                if key in data:
                    proj = data[key].get("project", "")
                    del data[key]
                    save_data(data)
                    message = f"Deleted port {port_to_rm} ({proj})"
                    message_attr = C_RED
                    if selected > 0 and selected >= len(display_ports) - 1:
                        selected -= 1
            confirming_delete = False
            continue

        if goto_mode:
            if ch == 27:  # Escape
                goto_term = ""
                goto_mode = False
            elif ch in (curses.KEY_BACKSPACE, 127, 8):
                goto_term = goto_term[:-1]
            elif ch in (10, 13):  # Enter
                if goto_term:
                    target = int(goto_term) if goto_term.isdigit() else -1
                    # Find the closest port in display_ports
                    best_idx = 0
                    best_dist = abs(display_ports[0] - target) if display_ports else 0
                    for idx_i, p in enumerate(display_ports):
                        if p == target:
                            best_idx = idx_i
                            break
                        d = abs(p - target)
                        if d < best_dist:
                            best_dist = d
                            best_idx = idx_i
                    selected = best_idx
                goto_term = ""
                goto_mode = False
            elif 48 <= ch <= 57:  # 0-9
                goto_term += chr(ch)
            continue

        if searching:
            if ch == 27:  # Escape
                search_term = ""
                searching = False
                selected = 0
            elif ch in (curses.KEY_BACKSPACE, 127, 8):
                search_term = search_term[:-1]
                selected = 0
            elif ch in (10, 13):  # Enter
                searching = False
            elif 32 <= ch < 127:
                search_term += chr(ch)
                selected = 0
            continue

        if ch in (ord("q"), ord("Q")):
            break
        elif ch in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
        elif ch in (ord("j"), curses.KEY_DOWN):
            if selected < len(display_ports) - 1:
                selected += 1
        elif ch in (ord("g"),):  # top
            selected = 0
        elif ch in (ord("G"),):  # bottom
            selected = max(0, len(display_ports) - 1)
        elif ch in (ord("/"),):
            searching = True
            search_term = ""
            selected = 0
        elif ch == ord(":"):
            goto_mode = True
            goto_term = ""
        elif ch in (ord("r"), ord("R")):
            listening = get_listening_info()
            data = load_data()
        elif ch in (ord("d"), ord("D")):
            if display_ports:
                port_to_rm = display_ports[selected]
                key = str(port_to_rm)
                if key in data:
                    confirming_delete = True
                else:
                    message = f"Port {port_to_rm} is not registered"
                    message_attr = C_DIM
        elif ch in (ord("a"), ord("A")):
            # Add prompt — temporarily exit curses
            curses.def_prog_mode()
            curses.endwin()
            new_port = tui_prompt_add()
            curses.reset_prog_mode()
            stdscr.clear()
            if new_port:
                data = load_data()
                listening = get_listening_info()


def tui_prompt_add():
    """Interactive add prompt outside curses. Returns port string or None."""
    print(f"\n  {BOLD}Reserve a port{RESET}\n")

    try:
        port_str = input("  Port: ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if not port_str.isdigit() or not (1 <= int(port_str) <= 65535):
        print(f"  {RED}Invalid port number{RESET}")
        input("  Press Enter to continue...")
        return None

    try:
        project = input("  Project: ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if not project:
        print(f"  {RED}Project name required{RESET}")
        input("  Press Enter to continue...")
        return None

    try:
        ptype = input("  Type (web/api/db/cache/proxy/other) [other]: ").strip() or "other"
        tags_raw = input("  Tags (comma-separated) []: ").strip()
    except (EOFError, KeyboardInterrupt):
        return None

    tags = [t.strip() for t in tags_raw.split(",") if t.strip()] if tags_raw else []

    data = load_data()
    data[port_str] = {
        "port": int(port_str),
        "project": project,
        "type": ptype,
        "description": "",
        "tags": tags,
        "meta": {},
    }
    save_data(data)
    return port_str


# ── Usage ─────────────────────────────────────────────────────────────────────
def usage():
    print(f"""{BOLD}ports{RESET} — local dev port registry

{BOLD}Usage:{RESET}
  ports                        Launch interactive TUI
  ports list [--active|--reserved|--available]
  ports add <port> <project> [key=value...]
  ports rm <port>              Remove a port reservation
  ports check <port>           Check port status

{BOLD}Status is auto-detected:{RESET}
  {GREEN}●{RESET} ACTIVE     reserved + port is listening
  {YELLOW}◐{RESET} RESERVED   reserved but port is idle
  {DIM}○{RESET} —          well-known port, available
  {MAGENTA}●{RESET} IN USE     something is listening (not registered)

{BOLD}Examples:{RESET}
  ports add 3000 my-app type=web tags=react,frontend
  ports add 5432 main-db type=db tags=postgres
  ports check 8080""")


# ── Main dispatch ─────────────────────────────────────────────────────────────
def main():
    args = sys.argv[1:]

    if not args:
        curses.wrapper(tui_main)
        return

    cmd = args[0]

    if cmd == "list":
        cmd_list(args[1:])
    elif cmd == "add":
        cmd_add(args[1:])
    elif cmd in ("rm", "remove"):
        cmd_rm(args[1:])
    elif cmd == "check":
        cmd_check(args[1:])
    elif cmd in ("help", "--help", "-h"):
        usage()
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
